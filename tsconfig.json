{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "paths": {
      "#commands/*": ["./src/commands/*.ts"],
      "#command": ["./src/structures/classes/command.ts"],
      "#context": ["./src/structures/classes/context.ts"],
      "#config": ["./src/config/config.ts"],
      "#emoji": ["./src/config/emoji.ts"],
      "#dbManager": ["./src/database/manager.ts"],
      "#structures/*": ["./src/structures/*.ts"],
      "#database/*": ["./src/database/*.ts"],
      "#config/*": ["./src/config/*.ts"],
      "#utils": ["./src/utils/index.ts"],
      "#utils/logger": ["./src/utils/index.ts"],
      "#utils/functions": ["./src/utils/functions.ts"],
      "#utils/feedbackManager": ["./src/utils/feedbackManager.ts"],
      "#utils/webhookLogger": ["./src/utils/webhookLogger.ts"],
      "#utils/nekoHelper": ["./src/utils/nekoHelper.ts"],
      "#utils/roleplayHelper": ["./src/utils/roleplayHelper.ts"],
      "#utils/robloxApi": ["./src/utils/robloxApi.ts"],
      "#utils/audiomackHelper": ["./src/utils/audiomackHelper.ts"],
      "#events/*": ["./src/events/*.ts"],
      "#handlers/*": ["./src/structures/handlers/*.ts"],
      "#classes/*": ["./src/structures/classes/*.ts"],
      "#classes/Rei": ["./src/structures/classes/rei.ts"],
      "#structures/classes/Command": ["./src/structures/classes/command.ts"],
      "#structures/classes/Rei": ["./src/structures/classes/rei.ts"],
      "#db/*": ["./src/database/*.ts"],
      "#db/Manager": ["./src/database/manager.ts"],
      "#dbRepo/*": ["./src/database/repositories/*.ts"],
      "#dbSchema/*": ["./src/database/schema/*.ts"],
      "#dbServices/*": ["./src/database/services/*.ts"],
      "#src/*": ["./src/*.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "example"]
}
